# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://distribusi_user:distribusi_pass@localhost:5432/distribusi_pro?schema=public"

# ── NextAuth ───────────────────────────────────────────────────────────────────
# Secret key untuk JWT — generate: openssl rand -base64 32
NEXTAUTH_SECRET="ganti-dengan-secret-yang-kuat-minimal-32-karakter"

# URL aplikasi (tanpa trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV="development"

FONNTE_TOKEN="ganti-dengan-token-fonnte-anda"